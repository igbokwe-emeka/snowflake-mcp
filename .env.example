# Snowflake Credentials (optional - only needed if using local MCP server)
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DEMO_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Managed MCP Server Configuration
# The agent authenticates to the MCP server using the user's OAuth token directly.
# No separate server token needed — the user's token IS the credential.
MCP_SERVER_URL=your_mcp_server_url

# Gemini Enterprise OAuth Configuration
# AUTH_ID is generated when you register the OAuth resource in Gemini Enterprise
# This is used to retrieve user tokens from session state via: temp:{AUTH_ID}
AUTH_ID=snowflake-oauth

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key
